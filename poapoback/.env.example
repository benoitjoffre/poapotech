# Database
DATABASE_URL="postgresql://poapo:poapo_secret@localhost:5432/poapo?schema=public"

# Auth
JWT_SECRET="change_me_to_a_long_random_string_in_production"
JWT_EXPIRES_IN="7d"
MAGIC_LINK_EXPIRES_MIN=15

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your@email.com"
SMTP_PASS="your_app_password"
EMAIL_FROM="Poapo <no-reply@poapo.fr>"

# AI service
AI_SERVICE_URL="http://localhost:8000"
OPENAI_API_KEY="sk-..."

# App
PORT=5050
FRONTEND_URL="http://localhost:5173"
ADMIN_URL="http://localhost:5174"
NODE_ENV="development"

# Scaleway Object Storage (S3-compatible)
SCW_ACCESS_KEY=""
SCW_SECRET_KEY=""
SCW_BUCKET_NAME="poapo-assets"
SCW_REGION="fr-par"
SCW_ENDPOINT="https://s3.fr-par.scw.cloud"
